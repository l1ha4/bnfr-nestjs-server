NODE_ENV=production

APPLICATION_PORT=2412
APPLICATION_URL=https://api.example.com
ALLOWED_ORIGINS=https://admin.example.com

COOKIE_SECRET=replace_with_strong_secret
SESSION_SECRET=replace_with_strong_secret
SESSION_NAME=bnfr.sid
SESSION_DOMAIN=api.example.com
SESSION_MAX_AGE=30d
SESSION_HTTP_ONLY=true
SESSION_SECURE=true
SESSION_FOLDER=sessions:

POSTGRES_URL=postgresql://user:password@host:5432/db
REDIS_URL=redis://user:password@host:6379

BOT_TOKEN_SECRET=replace_with_32_plus_symbols_secret
GOOGLE_RECAPTCHA_SECRET_KEY=replace_with_recaptcha_secret
